<icu_chain locale="ar">
  <!-- 1. تنظيف أولي للأرقام والرموز -->
  <transliterate rule="\'>\ "/>
  <transliterate rule="[:Number:] { '-' >  "/>
  <transform rule="[:Control:] Any-Remove"/>
  
  <!-- 2. التقسيم -->
  <tokenize rule="l"/>
  
  <!-- 3. إزالة الرموز والمسافات -->
  <transform rule="[[:WhiteSpace:][:Punctuation:]] Remove"/>
  
  <!-- 4. معالجة التشكيل وتوحيد الحروف (Normalization) -->
  <transform rule="NFD"/>
  <transform rule="[:Nonspacing Mark:] Remove"/>
  <transform rule="NFC"/>

  <!-- توحيد الألفات (أ إ آ) إلى ا -->
  <transliterate rule="[أإآٱ] > ا"/>
  
  <!-- توحيد الياء المتطرفة فقط (في آخر الكلمة) -->
  <transliterate rule="ى$ > ي"/>
  
  <!-- توحيد التاء المربوطة في آخر الكلمة -->
  <transliterate rule="ة$ > ه"/>

  <!-- ================================================== -->
  <!-- 4.5 قائمة الاستثناءات (حماية الـ الأصلية) - موسعة -->
  <!-- نقوم بإضافة رمز _ لحماية الكلمة من الحذف اللاحق -->
  <!-- ================================================== -->
  
  <!-- أسماء الله الحسنى وكلمات دينية -->
  <transliterate rule="^الله > _الله"/>
  <transliterate rule="^بالله > _بالله"/>
  <transliterate rule="^والله > _والله"/>
  <transliterate rule="^تالله > _تالله"/>
  <transliterate rule="^لله > _لله"/>
  <transliterate rule="^اله > _اله"/> <!-- إله -->
  <transliterate rule="^الهة > _الهة"/> <!-- آلهة -->

  <!-- أسماء علم وأشخاص (إلياس، أليس، إلخ) -->
  <transliterate rule="^الياس > _الياس"/>
  <transliterate rule="^الياسين > _الياسين"/>
  <transliterate rule="^اليس > _اليس"/>
  <transliterate rule="^اليسا > _اليسا"/>
  <transliterate rule="^اليكس > _اليكس"/>
  <transliterate rule="^الكسندر > _الكسندر"/>
  <transliterate rule="^الما > _الما"/>
  <transliterate rule="^الفت > _الفت"/> <!-- ألفت -->
  <transliterate rule="^اليف > _اليف"/> <!-- أليف -->

  <!-- أسماء دول وأماكن -->
  <transliterate rule="^المانيا > _المانيا"/>
  <transliterate rule="^البانيا > _البانيا"/>
  <transliterate rule="^الاسكا > _الاسكا"/>
  <transliterate rule="^الاباما > _الاباما"/>
  <transliterate rule="^الزاس > _الزاس"/>
  <transliterate rule="^الماظة > _الماظة"/>

  <!-- كلمات شائعة ومصطلحات -->
  <transliterate rule="^الوان > _الوان"/>
  <transliterate rule="^العاب > _العاب"/>
  <transliterate rule="^الماس > _الماس"/>
  <transliterate rule="^البان > _البان"/>
  <transliterate rule="^الحان > _الحان"/>
  <transliterate rule="^اليم > _اليم"/>
  <transliterate rule="^الفاظ > _الفاظ"/>
  <transliterate rule="^السون > _السون"/>
  <transliterate rule="^المنيوم > _المنيوم"/>
  <transliterate rule="^الكترون > _الكترون"/>
  <transliterate rule="^الكترونيات > _الكترونيات"/>
  <transliterate rule="^الكتروني > _الكتروني"/>
  <transliterate rule="^الياف > _الياف"/> <!-- ألياف -->
  <transliterate rule="^البوم > _البوم"/> <!-- ألبوم -->
  <transliterate rule="^البومات > _البومات"/>
  <transliterate rule="^الف > _الف"/> <!-- ألف -->
  <transliterate rule="^الفين > _الفين"/>
  <transliterate rule="^الفية > _الفية"/>
  <transliterate rule="^الوف > _الوف"/>

  <!-- مصادر وأفعال تبدأ بهمزة (إلهام، إلغاء، ألم) -->
  <transliterate rule="^الم > _الم"/> <!-- ألم -->
  <transliterate rule="^الام > _الام"/> <!-- آلام -->
  <transliterate rule="^الهام > _الهام"/> <!-- إلهام -->
  <transliterate rule="^الحاد > _الحاد"/> <!-- إلحاد -->
  <transliterate rule="^الزام > _الزام"/> <!-- إلزام -->
  <transliterate rule="^الغاء > _الغاء"/> <!-- إلغاء -->
  <transliterate rule="^القاء > _القاء"/> <!-- إلقاء -->
  <transliterate rule="^الحاق > _الحاق"/> <!-- إلحاق -->
  <transliterate rule="^المان > _المان"/> <!-- إلمام -->
  <transliterate rule="^الفة > _الفة"/> <!-- ألفة -->
  <transliterate rule="^الية > _الية"/> <!-- آلية -->
  <transliterate rule="^الي > _الي"/> <!-- آلي -->
  <transliterate rule="^الق > _الق"/> <!-- ألق -->

  <!-- أدوات وضمائر وظروف (لا يجب حذف ال منها) -->
  <transliterate rule="^الذي > _الذي"/>
  <transliterate rule="^التي > _التي"/>
  <transliterate rule="^الذين > _الذين"/>
  <transliterate rule="^اللاتي > _اللاتي"/>
  <transliterate rule="^اللواتي > _اللواتي"/>
  <transliterate rule="^اللائي > _اللائي"/>
  <transliterate rule="^الان > _الان"/> <!-- الآن -->
  <transliterate rule="^الا > _الا"/> <!-- إلا -->
  <transliterate rule="^الي > _الي"/> <!-- إلي -->
  <transliterate rule="^الى > _الى"/> <!-- إلى -->
  <transliterate rule="^الو > _الو"/> <!-- ألو -->

  <!-- كلمات أجنبية معربة شائعة -->
  <transliterate rule="^الترا > _الترا"/> <!-- Ultra -->
  <transliterate rule="^التيما > _التيما"/>
  <transliterate rule="^الفا > _الفا"/> <!-- Alpha -->
  <transliterate rule="^الما > _الما"/> <!-- Alma -->

  <!-- ================================================== -->

