  <!-- 6. المترادفات (Synonyms) - توحيد المصطلحات -->
  <!-- يتم وضعها هنا بعد إزالة الـ التعريف لضمان شمولية البحث -->
  <!-- ================================================== -->
  
  <!-- أجهزة وتقنية (توحيد المصطلحات التقنية) -->
